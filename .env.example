# --- demo agents ---
MCP_URL=http://localhost:3001/mcp
USER_ADDRESS=                 # taker's Mantle address that RECEIVES the rebate
ANTHROPIC_API_KEY=            # optional: enables the LLM resolver (else policy fallback)

# --- Mantle MAINNET settlement (REAL MNT) ---
MANTLE_RPC=https://rpc.mantle.xyz   # chainId 5000, gas + rebate paid in MNT
PRIVATE_KEY=                  # winning RESOLVER's key (pays gas + sends the rebate)
FLOW_RECEIPT_ADDRESS=         # set after deploying packages/contracts
REBATE_MNT=0.001              # rebate sent per won fill — keep tiny, it's real money
